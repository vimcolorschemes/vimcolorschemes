{
  "name": "vimcolorschemes",
  "version": "5.2.1",
  "description": "The ultimate resource for vim/neovim color schemes.",
  "author": "@reobin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vimcolorschemes/vimcolorschemes"
  },
  "bugs": {
    "url": "https://github.com/vimcolorschemes/vimcolorschemes/issues"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "lint.check": "eslint .",
    "test": "vitest run",
    "test.watch": "vitest",
    "format": "prettier --write .",
    "format.check": "prettier --check .",
    "seed": "./database/seed",
    "tsc": "tsc --noEmit",
    "check": "pnpm run --parallel '/^(lint.check|format.check|tsc|test)$/'",
    "check.fix": "pnpm lint && pnpm format && pnpm run --parallel '/^(tsc|test)$/'",
    "preinstall": "npx only-allow pnpm"
  },
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@tanstack/react-query": "^5.99.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@next/bundle-analyzer": "16.2.4",
    "@next/eslint-plugin-next": "16.2.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "libsql"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
