{
  "name": "vimcolorschemes",
  "version": "6.0.1",
  "description": "The ultimate resource for vim/neovim color schemes.",
  "author": "@reobin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vimcolorschemes/vimcolorschemes"
  },
  "bugs": {
    "url": "https://github.com/vimcolorschemes/vimcolorschemes/issues"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "lint.check": "eslint .",
    "test": "vitest run",
    "test.watch": "vitest",
    "format": "prettier --write .",
    "format.check": "prettier --check .",
    "seed": "./database/seed",
    "tc": "tsc --noEmit",
    "check": "pnpm run --parallel '/^(lint.check|format.check|tc|test)$/'",
    "check.fix": "pnpm lint && pnpm format && pnpm run --parallel '/^(tc|test)$/'",
    "preinstall": "npx only-allow pnpm"
  },
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@tanstack/react-query": "^5.100.14",
    "classnames": "^2.5.1",
    "date-fns": "^4.4.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.6",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
