{
  "name": "vimcolorschemes",
  "version": "6.0.0",
  "description": "The ultimate resource for vim/neovim color schemes.",
  "author": "@reobin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vimcolorschemes/vimcolorschemes"
  },
  "bugs": {
    "url": "https://github.com/vimcolorschemes/vimcolorschemes/issues"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "lint.check": "eslint .",
    "test": "vitest run",
    "test.watch": "vitest",
    "format": "prettier --write .",
    "format.check": "prettier --check .",
    "seed": "./database/seed",
    "tc": "tsc --noEmit",
    "check": "pnpm run --parallel '/^(lint.check|format.check|tc|test)$/'",
    "check.fix": "pnpm lint && pnpm format && pnpm run --parallel '/^(tc|test)$/'",
    "preinstall": "npx only-allow pnpm"
  },
  "engines": {
    "node": "24"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@tanstack/react-query": "^5.100.9",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.5",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.2.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "onlyBuiltDependencies": [
      "libsql"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
